<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title – Solar Energy Store</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>

@{
    var userName = Context.Session.GetString("UserName");
    var role = Context.Session.GetString("Role");
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<!-- TOP BAR -->
<div class="topbar d-none d-md-block">
    <div class="inner">
        @if (userName == null)
        {
            <a href="/Account/Login">Sign In</a>
            <a href="/Account/Register">Create Account</a>
        }
        else
        {
            <span style="color:#aec6e8;">Welcome, @userName</span>
            <a href="/Account/Logout">Logout</a>
        }
        <a href="/Home/Contact">Contact</a>
    </div>
</div>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-light bg-white navbar-solar">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <span class="brand-icon">☀️</span>
            <span>Solar Store<span class="brand-sub">CLEAN ENERGY</span></span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link @(controller=="Home"&&action=="Index"?"active":"")" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(controller=="Product"?"active":"")" href="/Product">Products</a>
                </li>
                @if (userName != null)
                {
                    <li class="nav-item">
                        <a class="nav-link @(controller=="Customer"?"active":"")" href="/Customer/Orders">My Orders</a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link @(action=="About"?"active":"")" href="/Home/About">About Solar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(action=="Contact"?"active":"")" href="/Home/Contact">Contact</a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto align-items-center gap-2">
                @if (userName == null)
                {
                    <li class="nav-item">
                        <a class="btn-nav-outline nav-link" href="/Account/Login">Sign In</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn-nav-solid nav-link" href="/Account/Register">Get Started</a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Profile">👤 @userName</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Logout">Logout</a>
                    </li>
                    if (role == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-admin fw-bold" href="/Admin">⚙️ Admin</a>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
</nav>

<!-- ALERTS -->
<div class="container mt-2">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
</div>

<!-- PAGE CONTENT -->
@RenderBody()

<!-- FOOTER -->
<footer class="site-footer">
    <div class="container">
        <div class="row g-4 pb-5">
            <div class="col-lg-4 footer-brand">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="brand-icon">☀️</div>
                    <div>
                        <div style="color:white;font-weight:800;font-size:17px;">Solar Store</div>
                        <div style="font-size:10px;letter-spacing:2px;color:#9dbbd6;">CLEAN ENERGY</div>
                    </div>
                </div>
                <p>Your trusted source for premium solar energy products.</p>
            </div>
            <div class="col-6 col-lg-2 footer-col">
                <h5>Products</h5>
                <a href="/Product">Solar Panels</a>
                <a href="/Product?category=Inverter">Inverters</a>
                <a href="/Product?category=Battery">Batteries</a>
                <a href="/Product?category=Accessory">Accessories</a>
            </div>
            <div class="col-6 col-lg-2 footer-col">
                <h5>Account</h5>
                <a href="/Account/Login">Sign In</a>
                <a href="/Account/Register">Register</a>
                @if (role == "Admin") { <a href="/Admin">Admin Panel</a> }
            </div>
        </div>
        <div class="footer-bottom">
            <span>&copy; @DateTime.Now.Year Solar Energy Store. All rights reserved.</span>
            <span>Clean Energy for a Better Future ☀️</span>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("scripts", required: false)
</body>
</html>
