@model List<SolarStore.Models.User>
@{ ViewBag.Title = "Manage Users"; Layout = "_AdminLayout"; }

<h4 class="mb-4">Customers (@Model.Count(u => u.Role == "Customer"))</h4>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr><th>Name</th><th>Email</th><th>Role</th><th>Joined</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td><strong>@u.FullName</strong></td>
                        <td>@u.Email</td>
                        <td>
                            @if (u.Role == "Admin") { <span class="badge bg-danger">Admin</span> }
                            else { <span class="badge bg-primary">Customer</span> }
                        </td>
                        <td>@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <a href="/Admin/EditUser/@u.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            @if (u.Role != "Admin")
                            {
                                <form method="post" action="/Admin/DeleteUser/@u.Id" class="d-inline"
                                      onsubmit="return confirm('Delete @u.FullName?')">
                                    <button class="btn btn-sm btn-outline-danger ms-1">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
