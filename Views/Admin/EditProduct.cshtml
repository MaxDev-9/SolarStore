@model SolarStore.Models.Product
@{ ViewBag.Title = "Edit Product"; Layout = "_AdminLayout"; }

<div style="max-width:680px;">
    <h4 class="mb-4">Edit Product</h4>

    <form method="post" action="/Admin/EditProduct/@Model.Id">
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="card border-0 shadow-sm p-4">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-600">Product Name *</label>
                    <input name="Name" value="@Model.Name" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-600">Category *</label>
                    <select name="Category" class="form-select">
                        @foreach (var c in new[]{"Panel","Inverter","Battery","Accessory"})
                        {
                            <option value="@c" selected="@(Model.Category==c ? "selected" : null)">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-600">Price ($) *</label>
                    <input name="Price" value="@Model.Price" type="number" step="0.01" min="0" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-600">Stock *</label>
                    <input name="Stock" value="@Model.Stock" type="number" min="0" class="form-control" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-600">Description</label>
                    <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-600">Image URL</label>
                    <input name="ImageUrl" value="@Model.ImageUrl" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input name="IsActive" type="checkbox" class="form-check-input" id="isActive" value="true" @(Model.IsActive?"checked":"") />
                        <label class="form-check-label" for="isActive">Active (visible to customers)</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-3 pt-2">
                    <button class="btn btn-solar-primary">Save Changes</button>
                    <a href="/Admin/Products" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </form>
</div>
