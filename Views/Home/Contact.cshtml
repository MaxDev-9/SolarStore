@{ ViewBag.Title = "Contact Us"; }

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-6 text-center">
            <h1 class="fw-800 mb-3">📬 Contact Us</h1>
            <p class="lead text-muted">Have a question about solar energy or our products? We'd love to hear from you.</p>
        </div>
    </div>

    <div class="row g-5 justify-content-center">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-700 mb-4">Send Us a Message</h5>
                <div class="mb-3">
                    <label class="form-label fw-600">Your Name</label>
                    <input type="text" class="form-control" placeholder="John Smith" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-600">Email Address</label>
                    <input type="email" class="form-control" placeholder="john@example.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-600">Subject</label>
                    <input type="text" class="form-control" placeholder="Product inquiry..." />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-600">Message</label>
                    <textarea class="form-control" rows="4" placeholder="Tell us how we can help..."></textarea>
                </div>
                <button class="btn btn-warning fw-700 w-100">Send Message</button>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 mb-3">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:1.8rem;">📧</div>
                    <div>
                        <div class="fw-700">Email</div>
                        <div class="text-muted">support@@solarstore.com</div>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm p-4 mb-3">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:1.8rem;">📞</div>
                    <div>
                        <div class="fw-700">Phone</div>
                        <div class="text-muted">+1 (800) 765-4321</div>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm p-4 mb-3">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:1.8rem;">🕐</div>
                    <div>
                        <div class="fw-700">Business Hours</div>
                        <div class="text-muted">Mon–Fri, 9am – 6pm EST</div>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm p-4">
                <div class="d-flex align-items-center gap-3">
                    <div style="font-size:1.8rem;">📍</div>
                    <div>
                        <div class="fw-700">Address</div>
                        <div class="text-muted">123 Solar Way, San Diego, CA 92101</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
