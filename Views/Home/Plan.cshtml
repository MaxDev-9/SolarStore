@{ ViewBag.Title = "Plan Your Solar System"; }

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-7 text-center">
            <h1 class="fw-800 mb-3">⚡ Plan Your Solar System</h1>
            <p class="lead text-muted">Use our simple guide to figure out how many panels and what equipment you need.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
                <div style="font-size:2rem;font-weight:800;color:#f59e0b;">1</div>
                <h6 class="fw-700 mt-2">Check Your Bill</h6>
                <p class="text-muted small">Find your average monthly kWh usage on your electricity bill.</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
                <div style="font-size:2rem;font-weight:800;color:#f59e0b;">2</div>
                <h6 class="fw-700 mt-2">Calculate Panels</h6>
                <p class="text-muted small">Divide your daily kWh usage by peak sun hours in your area (typically 4–6 hours).</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
                <div style="font-size:2rem;font-weight:800;color:#f59e0b;">3</div>
                <h6 class="fw-700 mt-2">Choose Inverter</h6>
                <p class="text-muted small">Select an inverter sized to match the total wattage of your solar array.</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
                <div style="font-size:2rem;font-weight:800;color:#f59e0b;">4</div>
                <h6 class="fw-700 mt-2">Add Battery (Optional)</h6>
                <p class="text-muted small">Add a battery bank if you want energy storage for nights and cloudy days.</p>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm p-5 mb-5" style="background:linear-gradient(135deg,#fffbeb,#fef3c7);">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h3 class="fw-800 mb-2">Quick Estimator</h3>
                <p class="text-muted mb-0">A typical home using <strong>900 kWh/month</strong> needs approximately <strong>20–25 panels</strong> of 400W each, a <strong>5kW inverter</strong>, and optionally a <strong>10kWh battery</strong>.</p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <a href="/Product" class="btn btn-warning fw-700 px-4">Shop Equipment</a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-700 mb-3">🏠 Residential System</h5>
                <ul class="list-unstyled">
                    <li class="py-2 border-bottom">📦 10–25 x 400W Mono Panels</li>
                    <li class="py-2 border-bottom">⚡ 5kW String Inverter</li>
                    <li class="py-2 border-bottom">🔋 10kWh Battery (optional)</li>
                    <li class="py-2">🔧 Roof Mount Kit + Wiring</li>
                </ul>
                <a href="/Product" class="btn btn-outline-warning fw-700 mt-3">View Products</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-700 mb-3">🏢 Commercial System</h5>
                <ul class="list-unstyled">
                    <li class="py-2 border-bottom">📦 50–200 x 400W Mono Panels</li>
                    <li class="py-2 border-bottom">⚡ Multiple 5kW Inverters</li>
                    <li class="py-2 border-bottom">🔋 Large Battery Bank</li>
                    <li class="py-2">🔧 Ground or Roof Mount System</li>
                </ul>
                <a href="/Home/Contact" class="btn btn-outline-warning fw-700 mt-3">Contact Us</a>
            </div>
        </div>
    </div>
</div>
