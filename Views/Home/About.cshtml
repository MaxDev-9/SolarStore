@{ ViewBag.Title = "About Solar Energy"; }

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8 text-center">
            <h1 class="fw-800 mb-3">☀️ About Solar Energy</h1>
            <p class="lead text-muted">Solar power is the cleanest, most abundant renewable energy source available. We help homes and businesses make the switch.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
                <div style="font-size:2.5rem;">🌍</div>
                <h5 class="fw-700 mt-3">Clean & Green</h5>
                <p class="text-muted">Solar panels produce zero emissions during operation, reducing your carbon footprint significantly.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
                <div style="font-size:2.5rem;">💰</div>
                <h5 class="fw-700 mt-3">Save Money</h5>
                <p class="text-muted">Most homeowners save 50–90% on electricity bills after installing solar panels. Payback period is typically 5–8 years.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
                <div style="font-size:2.5rem;">⚡</div>
                <h5 class="fw-700 mt-3">Energy Independence</h5>
                <p class="text-muted">Generate your own electricity and become less dependent on the grid. Add a battery to store excess energy.</p>
            </div>
        </div>
    </div>

    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <h2 class="fw-800 mb-3">How Solar Panels Work</h2>
            <p class="text-muted">Solar panels are made of photovoltaic (PV) cells that convert sunlight into direct current (DC) electricity. An inverter then converts that DC power into alternating current (AC) — the type used by your home appliances.</p>
            <p class="text-muted">Any excess electricity can be stored in a battery system or fed back into the grid. A complete solar system typically includes panels, an inverter, mounting hardware, and optionally a battery storage unit.</p>
            <a href="/Product" class="btn btn-warning fw-700 px-4 mt-2">Browse Our Products</a>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-700 mb-3">Quick Facts</h5>
                <ul class="list-unstyled">
                    <li class="py-2 border-bottom">☀️ <strong>1 hour</strong> of sunlight = enough energy to power Earth for a year</li>
                    <li class="py-2 border-bottom">📉 Solar panel costs have dropped <strong>90%</strong> since 2010</li>
                    <li class="py-2 border-bottom">🏠 Over <strong>3 million</strong> homes in the US have solar installed</li>
                    <li class="py-2">🔋 Battery storage can provide power for <strong>24+ hours</strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>
