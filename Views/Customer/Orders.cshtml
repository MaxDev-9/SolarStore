@model List<SolarStore.Models.Order>
@{ ViewBag.Title = "My Orders"; }

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-bag-check me-2"></i>My Orders</h2>
        <a href="/Product" class="btn btn-solar-primary"><i class="bi bi-plus me-1"></i>New Order</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bag-x" style="font-size:3rem;"></i>
            <p class="mt-3">No orders yet. <a href="/Product">Browse products</a></p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td><strong>#@o.Id</strong></td>
                            <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td>@o.OrderItems.Sum(i => i.Quantity) items</td>
                            <td class="fw-600">$@o.TotalAmount.ToString("N2")</td>
                            <td>
                                <span class="badge @StatusBadge(o.Status)">@o.Status</span>
                            </td>
                            <td>
                                <a href="/Customer/OrderDetails/@o.Id" class="btn btn-sm btn-outline-secondary">View</a>
                                @if (o.Status == "Pending")
                                {
                                    <a href="/Customer/EditOrder/@o.Id" class="btn btn-sm btn-outline-warning ms-1">Edit</a>
                                    <form method="post" action="/Customer/CancelOrder/@o.Id" class="d-inline"
                                          onsubmit="return confirm('Cancel this order?')">
                                        <button class="btn btn-sm btn-outline-danger ms-1">Cancel</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@functions {
    string StatusBadge(string status) => status switch {
        "Pending" => "bg-warning text-dark",
        "Processing" => "bg-info text-dark",
        "Shipped" => "bg-primary",
        "Delivered" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };
}
