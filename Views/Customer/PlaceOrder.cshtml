@{ ViewBag.Title = "Place Order";
   var product = (SolarStore.Models.Product)ViewBag.Product;
   var qty = (int)ViewBag.Qty; }

<div class="container py-5" style="max-width:600px;">
    <h2 class="mb-4"><i class="bi bi-cart-check me-2"></i>Place Order</h2>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex gap-3 align-items-center">
            @if (product.ImageUrl != null)
            {
                <img src="@product.ImageUrl" style="width:80px;height:80px;object-fit:cover;border-radius:8px;" />
            }
            <div>
                <div class="fw-700">@product.Name</div>
                <div class="text-muted small">@product.Category</div>
                <div class="product-price">$@product.Price.ToString("N2") each</div>
            </div>
        </div>
    </div>

    <form method="post" action="/Customer/PlaceOrder/@product.Id">
        <input type="hidden" name="productId" value="@product.Id" />

        <div class="mb-3">
            <label class="form-label fw-600">Quantity</label>
            <input type="number" name="qty" value="@qty" min="1" max="@product.Stock" class="form-control form-control-lg" style="max-width:120px;" required />
            <div class="text-muted small mt-1">@product.Stock available in stock</div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-600">Shipping Address</label>
            <textarea name="shippingAddress" class="form-control" rows="3" placeholder="Full delivery address…" required></textarea>
        </div>

        <div class="mb-4">
            <label class="form-label fw-600">Notes <span class="text-muted">(optional)</span></label>
            <textarea name="notes" class="form-control" rows="2" placeholder="Any special instructions…"></textarea>
        </div>

        <div class="d-flex gap-3">
            <button class="btn btn-solar-primary btn-lg flex-grow-1">
                <i class="bi bi-check-circle me-1"></i>Confirm Order
            </button>
            <a href="/Product/Details/@product.Id" class="btn btn-outline-secondary btn-lg">Cancel</a>
        </div>
    </form>
</div>
