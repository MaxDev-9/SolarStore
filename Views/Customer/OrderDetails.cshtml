@model SolarStore.Models.Order
@{ ViewBag.Title = $"Order #{Model.Id}"; }

<div class="container py-5" style="max-width:700px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Order #@Model.Id</h2>
        <a href="/Customer/Orders" class="btn btn-outline-secondary">← My Orders</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-sm-6">
                    <div class="text-muted small">Date</div>
                    <div class="fw-600">@Model.OrderDate.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted small">Status</div>
                    <span class="badge @(Model.Status=="Delivered"?"bg-success":Model.Status=="Cancelled"?"bg-danger":"bg-warning text-dark")">@Model.Status</span>
                </div>
                <div class="col-12 mt-3">
                    <div class="text-muted small">Shipping Address</div>
                    <div>@Model.ShippingAddress</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="col-12 mt-2">
                        <div class="text-muted small">Notes</div>
                        <div>@Model.Notes</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <h5 class="mb-3">Items</h5>
    <div class="card border-0 shadow-sm mb-4">
        <ul class="list-group list-group-flush">
            @foreach (var item in Model.OrderItems)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-600">@item.Product?.Name</div>
                        <div class="text-muted small">Qty: @item.Quantity × $@item.UnitPrice.ToString("N2")</div>
                    </div>
                    <div class="fw-700">$@((item.Quantity * item.UnitPrice).ToString("N2"))</div>
                </li>
            }
            <li class="list-group-item d-flex justify-content-between bg-light">
                <strong>Total</strong>
                <strong class="product-price">$@Model.TotalAmount.ToString("N2")</strong>
            </li>
        </ul>
    </div>

    @if (Model.Status == "Pending")
    {
        <div class="d-flex gap-3">
            <a href="/Customer/EditOrder/@Model.Id" class="btn btn-outline-warning">
                <i class="bi bi-pencil me-1"></i>Edit Order
            </a>
            <form method="post" action="/Customer/CancelOrder/@Model.Id"
                  onsubmit="return confirm('Are you sure you want to cancel this order?')">
                <button class="btn btn-outline-danger">
                    <i class="bi bi-x-circle me-1"></i>Cancel Order
                </button>
            </form>
        </div>
    }
</div>
