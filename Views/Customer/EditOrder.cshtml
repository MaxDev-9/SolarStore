@model SolarStore.Models.Order
@{ ViewBag.Title = $"Edit Order #{Model.Id}"; }

<div class="container py-5" style="max-width:550px;">
    <h2 class="mb-4"><i class="bi bi-pencil me-2"></i>Edit Order #@Model.Id</h2>

    <form method="post" action="/Customer/EditOrder/@Model.Id">
        <div class="mb-3">
            <label class="form-label fw-600">Shipping Address</label>
            <textarea name="shippingAddress" class="form-control" rows="3" required>@Model.ShippingAddress</textarea>
        </div>
        <div class="mb-4">
            <label class="form-label fw-600">Notes</label>
            <textarea name="notes" class="form-control" rows="2">@Model.Notes</textarea>
        </div>
        <div class="d-flex gap-3">
            <button class="btn btn-solar-primary flex-grow-1">Save Changes</button>
            <a href="/Customer/OrderDetails/@Model.Id" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
